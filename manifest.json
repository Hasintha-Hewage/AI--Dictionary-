{
  "manifest_version": 3,
  "name": "AIDictionary",
  "version": "1.0.0",
  "description": "Select any word on any webpage or PDF to get its definition from Google Gemini AI",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "http://*/*",
    "https://*/*",
    "file:///*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Dictionary Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*",
        "file:///*"
      ],
      "js": ["Content.js"],
      "all_frames": true,
      "run_at": "document_end"
    }
  ]
}
